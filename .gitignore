# Build artefacts — only the output dir + Wails cache; keep
# build/appicon.png and build/windows/icon.ico tracked so go-winres
# can embed the icon as a PE resource in CI.
/build/bin/
/build/.wails/
/bin/
*.exe

# go-winres output (regenerated by CI before each build)
cmd/*/rsrc_windows_*.syso
cmd/*/hashpoint_windows_*.syso
*.exe~
*.dll
*.so
*.dylib

# Wails
frontend/dist/
frontend/node_modules/
frontend/.vite/
frontend/wailsjs/

# Test
*.test
*.out
coverage.out
coverage.html

# IDE
.idea/
.vscode/
*.iml

# Claude Code local tool settings
.claude/

# OS
Thumbs.db
.DS_Store

# Local config / secrets
*.local.toml
.env
.env.local

# Azure Trusted Signing — endpoint + account names are deployment-specific
metadata.json

# Logs
*.log
log/

# HAR network captures — may contain real session cookies / CSRF tokens.
# Keep these strictly local; they are reference material only.
*.har
docs/har-samples/

# Local DB during development
*.db
*.db-journal
*.sqlite
*.sqlite3
